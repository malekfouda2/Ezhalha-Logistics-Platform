# ==================================================
# ezhalha Logistics Platform - Environment Variables
# ==================================================
# Copy this file to .env and fill in the values

# ==================================================
# DATABASE
# ==================================================
DATABASE_URL=postgresql://user:password@localhost:5432/ezhalha

# ==================================================
# SESSION & SECURITY
# ==================================================
# Generate a secure random string for session encryption
SESSION_SECRET=your-secure-session-secret-here
# Required in production. Keep this stable so encrypted integration credentials remain readable.
INTEGRATION_CONFIG_SECRET=your-dedicated-integration-encryption-secret-here

# ==================================================
# APPLICATION
# ==================================================
NODE_ENV=production
PORT=5000

# ==================================================
# EXTERNAL INTEGRATIONS (Optional)
# ==================================================

# FedEx API Integration
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
FEDEX_ACCOUNT_NUMBER=
FEDEX_WEBHOOK_SECRET=
FEDEX_SANDBOX=true
# Optional override for the FedEx Trade Documents Upload API
# Sandbox default: https://documentapitest.prod.fedex.com/sandbox
# Production default: https://documentapi.prod.fedex.com
FEDEX_DOCUMENT_BASE_URL=

# DHL MyDHL API Integration
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
# Sandbox default: https://express.api.dhl.com/mydhlapi/test
# Production default: https://express.api.dhl.com/mydhlapi
DHL_BASE_URL=

# Aramex Shipping API Integration
# Aramex is usually provisioned with these six account fields from their developer/support team.
ARAMEX_USERNAME=
ARAMEX_PASSWORD=
ARAMEX_ACCOUNT_NUMBER=
ARAMEX_ACCOUNT_PIN=
ARAMEX_ACCOUNT_ENTITY=
ARAMEX_ACCOUNT_COUNTRY_CODE=
# Test default: https://ws.dev.aramex.net
# Production default: https://ws.aramex.net
ARAMEX_BASE_URL=https://ws.dev.aramex.net
# Optional: set true to force local mock rates/shipments while credentials are pending.
ARAMEX_MOCK_MODE=false

# Gemini Invoice Extraction Fallback (Optional)
# Used for scanned invoices, image-based invoices, and weak PDF parsing fallbacks.
GEMINI_API_KEY=
# Recommended starting model: gemini-2.5-flash-lite
GEMINI_INVOICE_EXTRACTION_MODEL=gemini-2.5-flash-lite
# Optional: set to true to use Gemini even when deterministic parsing succeeds with warnings.
GEMINI_INVOICE_FALLBACK_ON_WARNING=false

# Tap Payments Integration
# Tap uses the same API base URL for test and live mode; the key determines the environment.
TAP_SECRET_KEY=
TAP_PUBLIC_KEY=
# Optional merchant ID from the Tap dashboard if your account requires it on charge requests.
TAP_MERCHANT_ID=
# Optional override if Tap changes the base URL in your environment.
TAP_BASE_URL=
# Enable this after Tap confirms saved cards are activated on your account.
TAP_ENABLE_SAVED_CARDS=false

# Zoho Books Integration
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
# Tax ids auto-resolve from the org if left blank (15% VAT + 0% zero-rated)
ZOHO_VAT_TAX_ID=
ZOHO_ZERO_TAX_ID=
# Cost-side sync (optional) — expenses/carrier payouts are skipped until these are set
ZOHO_EXPENSE_ACCOUNT_ID=
ZOHO_CARRIER_EXPENSE_ACCOUNT_ID=
ZOHO_PAID_THROUGH_ACCOUNT_ID=

# ==================================================
# OBJECT STORAGE (Replit-managed)
# ==================================================
# These are automatically set by Replit when object storage is configured
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=

# ==================================================
# EMAIL (Optional - for notifications)
# ==================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ezhalha.com

# ==================================================
# LOGGING
# ==================================================
LOG_DIR=./logs
LOG_LEVEL=info

# ==================================================
# APPLICATION URL
# ==================================================
APP_URL=https://your-domain.com

# ==================================================
# ADMIN NOTIFICATIONS
# ==================================================
# Email address to receive admin notifications (new applications, etc.)
ADMIN_EMAIL=
